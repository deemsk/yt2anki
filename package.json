{
  "name": "yt2anki",
  "version": "1.0.0",
  "description": "Create Anki cards from YouTube videos for German learning",
  "type": "module",
  "bin": {
    "yt2anki": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js clip",
    "clip": "node src/index.js clip",
    "add": "node src/index.js add",
    "process": "node src/index.js process",
    "test": "node src/index.js test",
    "check": "node src/index.js check",
    "config": "node src/index.js config",
    "init": "node src/index.js init",
    "bookmarklet": "node scripts/build-bookmarklet.js && cat bookmarklet/bookmarklet.txt | pbcopy && echo 'Bookmarklet copied to clipboard'"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.52.0",
    "ora": "^8.0.1",
    "chalk": "^5.3.0"
  }
}
